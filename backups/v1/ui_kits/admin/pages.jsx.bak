/* Admin "Sayfalar" module — lists site pages; manage the homepage's sections
   (reorder, show/hide, add Image/Video/Text blocks, edit their content) and
   edit text-page content overrides. Drives the live site via window.MarkaPages. */
const { useState: usePgState } = React;
const PG = () => window.MarkaPages;

function PagesM() {
  const [page, setPage] = usePgState(null); // null = list
  if (page) {
    const meta = PG().getPage(page);
    return meta.editable === "sections"
      ? <HomeSectionManager meta={meta} onBack={() => setPage(null)} />
      : <TextPageEditor meta={meta} onBack={() => setPage(null)} />;
  }
  return (
    <AdmCard title="Sayfalar" desc={`${PG().PAGES.length} sayfa`}>
      <table className="adm-table">
        <thead><tr><th>Sayfa</th><th>URL</th><th>Düzenleme</th><th></th></tr></thead>
        <tbody>
          {PG().PAGES.map(p => (
            <tr key={p.id}>
              <td className="ti">{p.label}</td>
              <td style={{ fontFamily: "var(--font-mono)", color: "var(--text-muted)" }}>/{p.path}</td>
              <td><Badge tone={p.editable === "sections" ? "green" : "muted"}>{p.editable === "sections" ? "Bölümler + metin" : "Yalnızca metin"}</Badge></td>
              <td><div className="adm-row-actions"><button className="adm-btn adm-btn--ghost" onClick={() => setPage(p.id)}><Icon name="edit" size={14} /> Düzenle</button></div></td>
            </tr>
          ))}
        </tbody>
      </table>
    </AdmCard>
  );
}

const SECTION_TYPES = [
  { type: "image", label: "Görsel bölümü", icon: "media" },
  { type: "video", label: "Video bölümü", icon: "media" },
  { type: "text", label: "Metin bölümü", icon: "pages" },
];

function HomeSectionManager({ meta, onBack }) {
  const [, force] = usePgState(0);
  const rerender = () => force(n => n + 1);
  const [addOpen, setAddOpen] = usePgState(false);
  const [editing, setEditing] = usePgState(null); // custom section id
  const sections = PG().homeSections();

  const act = (fn) => { fn(); rerender(); };
  const editSec = sections.find(s => s.id === editing && s.kind === "custom");

  return (
    <div>
      <div className="ed-toolbar">
        <button className="ed-back" onClick={onBack}><Icon name="chevron" size={14} style={{ transform: "rotate(90deg)" }} /> Sayfalar</button>
        <span className="adm-badge adm-badge--green">{meta.label} — bölümler</span>
        <span className="sp" />
        <a className="adm-btn adm-btn--ghost" href="../website/index.html" target="_blank" rel="noopener"><Icon name="external" size={15} /> Canlı gör</a>
        <button className="adm-btn adm-btn--primary" onClick={() => setAddOpen(true)}><Icon name="plus" size={15} /> Bölüm ekle</button>
      </div>

      <AdmCard title="Bölümler" desc="Sırala, gizle/göster, görsel & video bölümleri ekle">
        <ul className="seclist">
          {sections.map((s, i) => (
            <li key={s.id} className={`seclist__row ${s.hidden ? "is-hidden" : ""}`}>
              <span className="seclist__order">{String(i + 1).padStart(2, "0")}</span>
              <span className={`seclist__ic ${s.kind === "custom" ? "is-custom" : ""}`}><Icon name={s.kind === "custom" ? (s.type === "video" ? "media" : s.type === "text" ? "pages" : "media") : "projects"} size={15} /></span>
              <div className="seclist__meta">
                <b>{s.kind === "custom" ? (s.title || "Özel bölüm") : s.label}</b>
                <span>{s.kind === "custom" ? `Özel · ${s.type === "video" ? "Video" : s.type === "text" ? "Metin" : "Görsel"}` : "Yerleşik bölüm"}{s.locked ? " · sabit" : ""}</span>
              </div>
              <div className="seclist__actions">
                <button className="adm-iconbtn" disabled={i === 0} onClick={() => act(() => PG().move(s.id, -1))} aria-label="Yukarı"><Icon name="chevron" size={14} style={{ transform: "rotate(180deg)" }} /></button>
                <button className="adm-iconbtn" disabled={i === sections.length - 1} onClick={() => act(() => PG().move(s.id, 1))} aria-label="Aşağı"><Icon name="chevron" size={14} /></button>
                {!s.locked && <button className="adm-iconbtn" onClick={() => act(() => PG().toggleHidden(s.id))} aria-label="Gizle/Göster"><Icon name="eye" size={14} /></button>}
                {s.kind === "custom" && <>
                  <button className="adm-iconbtn" onClick={() => setEditing(s.id)} aria-label="Düzenle"><Icon name="edit" size={14} /></button>
                  <button className="adm-iconbtn" onClick={() => act(() => PG().removeCustom(s.id))} aria-label="Sil"><Icon name="trash" size={14} /></button>
                </>}
              </div>
            </li>
          ))}
        </ul>
        <p className="seclist__hint"><Icon name="ai" size={13} /> Yerleşik bölümlerin metinleri ana sayfada doğrudan düzenlenir; burada sıralama, görünürlük ve yeni görsel/video bölümleri yönetilir.</p>
      </AdmCard>

      {addOpen && (
        <Modal title="Bölüm ekle" onClose={() => setAddOpen(false)}>
          <p style={{ color: "var(--text-muted)", fontSize: "var(--fs-sm)", marginBottom: "var(--space-4)" }}>Yeni bölüm listenin sonuna eklenir; ardından oklarla istediğin yere taşıyabilirsin.</p>
          <div className="addsec-grid">
            {SECTION_TYPES.map(t => (
              <button key={t.type} className="addsec" onClick={() => { const id = PG().addCustom(t.type); setAddOpen(false); setEditing(id); }}>
                <span className="addsec__ic"><Icon name={t.icon} size={22} /></span>
                <b>{t.label}</b>
                <span>{t.type === "image" ? "Tam genişlik görsel" : t.type === "video" ? "Yükle veya embed (YouTube/Vimeo)" : "Başlık + paragraf"}</span>
              </button>
            ))}
          </div>
        </Modal>
      )}

      {editSec && <CustomSectionEditor section={editSec} onClose={() => setEditing(null)} onChange={(patch) => act(() => PG().updateCustom(editSec.id, patch))} />}
    </div>
  );
}

function CustomSectionEditor({ section, onClose, onChange }) {
  const s = section;
  return (
    <Drawer title="Bölümü düzenle" subtitle={s.type === "video" ? "Video bölümü" : s.type === "text" ? "Metin bölümü" : "Görsel bölümü"} onClose={onClose}
      footer={<button className="adm-btn adm-btn--primary" onClick={onClose}>Bitti</button>}>
      <Field label="Başlık"><input className="adm-input" value={s.title || ""} onChange={e => onChange({ title: e.target.value })} placeholder="Bölüm başlığı" /></Field>
      <Field label="Açıklama metni"><textarea className="adm-textarea" style={{ minHeight: "6rem" }} value={s.text || ""} onChange={e => onChange({ text: e.target.value })} placeholder="Kısa açıklama (opsiyonel)" /></Field>
      {s.type === "image" && <ImageUpload label="Görsel" ratio="16/9" value={s.src} onChange={v => onChange({ src: v })} hint="tam genişlik" />}
      {s.type === "video" && <>
        <Field label="Video bağlantısı (YouTube / Vimeo / .mp4)"><input className="adm-input" value={s.url || ""} onChange={e => onChange({ url: e.target.value })} placeholder="https://youtu.be/..." /></Field>
        <ImageUpload label="Kapak görseli (poster)" ratio="16/9" value={s.src} onChange={v => onChange({ src: v })} />
      </>}
    </Drawer>
  );
}

function TextPageEditor({ meta, onBack }) {
  const [, force] = usePgState(0);
  // generic editable text blocks per text page (title + intro + closing)
  const FIELDS = [
    { key: "title", label: "Sayfa başlığı", type: "input" },
    { key: "intro", label: "Giriş metni", type: "area" },
    { key: "body", label: "Gövde metni", type: "area" },
  ];
  return (
    <div>
      <div className="ed-toolbar">
        <button className="ed-back" onClick={onBack}><Icon name="chevron" size={14} style={{ transform: "rotate(90deg)" }} /> Sayfalar</button>
        <span className="adm-badge adm-badge--muted">{meta.label} — metin</span>
        <span className="sp" />
        <a className="adm-btn adm-btn--ghost" href={`../website/${meta.path}`} target="_blank" rel="noopener"><Icon name="external" size={15} /> Canlı gör</a>
      </div>
      <AdmCard title={`${meta.label} metinleri`} desc="Bu sayfadaki metin alanlarını düzenleyin">
        {FIELDS.map(f => (
          <Field key={f.key} label={f.label}>
            {f.type === "area"
              ? <textarea className="adm-textarea" style={{ minHeight: "6rem" }} value={PG().getText(meta.id, f.key, "")} onChange={e => { PG().setText(meta.id, f.key, e.target.value); force(n => n + 1); }} placeholder="Metni buraya girin…" />
              : <input className="adm-input" value={PG().getText(meta.id, f.key, "")} onChange={e => { PG().setText(meta.id, f.key, e.target.value); force(n => n + 1); }} placeholder="Metni buraya girin…" />}
          </Field>
        ))}
        <p className="seclist__hint"><Icon name="ai" size={13} /> Metinler kaydedildi ve canlı sitede ilgili alanlara uygulanır.</p>
      </AdmCard>
    </div>
  );
}

Object.assign(window, { PagesM });
