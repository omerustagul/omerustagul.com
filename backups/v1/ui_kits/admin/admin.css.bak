/* ========================================================================
   MARKA ADMIN — modular control panel. Editorial brand language (green,
   General Sans) with dashboard structure. Composes the design-system tokens.
   ======================================================================== */
.adm *{ box-sizing:border-box; }
.adm{ display:grid; grid-template-columns:264px 1fr; min-height:100vh; background:var(--bg); color:var(--text); font-family:var(--font-sans); }

/* ---------- SIDEBAR ---------- */
.adm-side{ background:var(--ink-900); color:#fff; display:flex; flex-direction:column; padding:var(--space-5) var(--space-4); position:sticky; top:0; height:100vh; gap:var(--space-5); }
.adm-side__brand{ display:flex; align-items:center; justify-content:space-between; padding:.4rem .5rem var(--space-3); }
.adm-side__brand .brand{ color:#fff; font-size:1.35rem; font-weight:700; letter-spacing:-0.04em; }
.adm-side__brand .dot{ color:var(--accent); }
.adm-side__badge{ font-family:var(--font-mono); font-size:9px; letter-spacing:.16em; text-transform:uppercase; color:var(--ink-900); background:var(--accent); padding:.3em .55em; border-radius:var(--radius-pill); }
.adm-nav{ display:flex; flex-direction:column; gap:1.4rem; overflow-y:auto; flex:1; }
/* light, ultra-thin scrollbar on the always-dark sidebar */
.adm-side, .adm-nav{ scrollbar-color: rgba(255,255,255,.22) transparent; }
.adm-side ::-webkit-scrollbar-thumb, .adm-nav::-webkit-scrollbar-thumb{ background:rgba(255,255,255,.18); border:2px solid transparent; background-clip:padding-box; }
.adm-side ::-webkit-scrollbar-thumb:hover, .adm-nav::-webkit-scrollbar-thumb:hover{ background:rgba(255,255,255,.34); background-clip:padding-box; }
.adm-nav__group h5{ font-family:var(--font-mono); font-size:10px; letter-spacing:.16em; text-transform:uppercase; color:rgba(255,255,255,.4); margin:0 0 .6rem; padding-inline:.6rem; font-weight:500; }
.adm-nav__item{ display:flex; align-items:center; gap:.7rem; width:100%; text-align:left; background:none; border:0; color:rgba(255,255,255,.72); font-family:inherit; font-size:.92rem; padding:.6rem; border-radius:var(--radius-sm); cursor:pointer; transition:background var(--dur-fast), color var(--dur-fast); position:relative; }
.adm-nav__item:hover{ background:rgba(255,255,255,.06); color:#fff; }
.adm-nav__item.is-active{ background:var(--accent); color:var(--on-accent); font-weight:500; }
.adm-nav__ic{ width:18px; display:inline-flex; justify-content:center; flex:none; }
.adm-nav__item .tag{ margin-left:auto; font-family:var(--font-mono); font-size:10px; background:rgba(255,255,255,.12); padding:.15em .5em; border-radius:var(--radius-pill); }
.adm-nav__item.is-active .tag{ background:rgba(10,10,10,.18); }
.adm-side__user{ display:flex; align-items:center; gap:.7rem; padding:.6rem; border-top:1px solid rgba(255,255,255,.1); }
.adm-side__user .av{ width:36px; height:36px; border-radius:50%; background:var(--accent); color:var(--on-accent); display:grid; place-items:center; font-family:var(--font-mono); font-weight:600; font-size:.8rem; flex:none; }
.adm-side__user b{ font-size:.85rem; font-weight:600; display:block; }
.adm-side__user span{ font-size:.72rem; color:rgba(255,255,255,.5); }

/* ---------- MAIN ---------- */
.adm-main{ display:flex; flex-direction:column; min-width:0; }
.adm-top{ position:sticky; top:0; z-index:10; display:flex; align-items:center; gap:var(--space-4); padding:var(--space-4) var(--space-6); background:color-mix(in srgb,var(--bg) 85%,transparent); -webkit-backdrop-filter:blur(12px); backdrop-filter:blur(12px); border-bottom:1px solid var(--border); }
.adm-top__title{ font-size:1.3rem; font-weight:600; letter-spacing:-0.02em; }
.adm-top__sub{ font-size:var(--fs-sm); color:var(--text-muted); }
.adm-top__search{ margin-left:auto; display:flex; align-items:center; gap:.5rem; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-pill); padding:.5rem .9rem; min-width:220px; color:var(--text-muted); }
.adm-top__search input{ border:0; background:none; outline:none; font-family:inherit; font-size:var(--fs-sm); color:var(--text); width:100%; }
.adm-body{ padding:var(--space-6); display:flex; flex-direction:column; gap:var(--space-6); }

/* ---------- CARDS / GRID ---------- */
.adm-grid{ display:grid; gap:var(--space-5); }
.adm-grid--4{ grid-template-columns:repeat(4,1fr); }
.adm-grid--3{ grid-template-columns:repeat(3,1fr); }
.adm-grid--2{ grid-template-columns:repeat(2,1fr); }
.adm-card{ background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-lg); padding:var(--space-5); }
.adm-card__h{ display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-bottom:var(--space-4); }
.adm-card__h h3{ font-size:1.05rem; font-weight:600; }
.adm-card__h p{ font-size:var(--fs-sm); color:var(--text-muted); }

/* stat */
.stat-card{ background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-lg); padding:var(--space-5); display:flex; flex-direction:column; gap:.5rem; }
.stat-card__label{ font-family:var(--font-mono); font-size:var(--fs-xs); letter-spacing:.12em; text-transform:uppercase; color:var(--text-muted); }
.stat-card__val{ font-size:2rem; font-weight:600; letter-spacing:-0.03em; }
.stat-card__delta{ font-family:var(--font-mono); font-size:var(--fs-xs); display:inline-flex; gap:.3ch; }
.stat-card__delta.up{ color:var(--green-700); }
.stat-card__delta.down{ color:var(--signal-err); }

/* ---------- FORM ATOMS ---------- */
.adm-field{ display:flex; flex-direction:column; gap:.45rem; margin-bottom:var(--space-4); }
.adm-field > label{ font-family:var(--font-mono); font-size:var(--fs-label); letter-spacing:.1em; text-transform:uppercase; color:var(--text-muted); }
.adm-input, .adm-textarea, .adm-select{ width:100%; font-family:var(--font-sans); font-size:var(--fs-body); color:var(--text); background:var(--bg); border:1px solid var(--border); border-radius:var(--radius-sm); padding:.7rem .85rem; transition:border-color var(--dur-fast); }
.adm-input:focus, .adm-textarea:focus, .adm-select:focus{ outline:none; border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-tint); }
.adm-textarea{ resize:vertical; min-height:8rem; line-height:1.6; }

.adm-btn{ display:inline-flex; align-items:center; gap:.5ch; font-family:var(--font-sans); font-weight:500; font-size:var(--fs-sm); border-radius:clamp(2px, calc(var(--radius) * 4), 999px); padding:.6rem 1.1rem; cursor:pointer; border:1px solid transparent; transition:all var(--dur-fast) var(--ease-out); white-space:nowrap; }
.adm-btn--primary{ background:var(--accent); color:var(--on-accent); }
.adm-btn--primary:hover{ background:var(--accent-hover); }
.adm-btn--ghost{ background:transparent; border-color:var(--border); color:var(--text); }
.adm-btn--ghost:hover{ border-color:var(--border-strong); }
.adm-btn--dark{ background:var(--ink-900); color:#fff; }
.adm-btn:active{ transform:scale(.97); }
.adm-btn[disabled]{ opacity:.5; pointer-events:none; }

.adm-badge{ font-family:var(--font-mono); font-size:10px; letter-spacing:.08em; text-transform:uppercase; padding:.3em .6em; border-radius:var(--radius-pill); }
.adm-badge--green{ background:var(--accent-tint); color:var(--green-700); }
.adm-badge--muted{ background:var(--surface-muted); color:var(--text-muted); }
.adm-badge--warn{ background:#fdf0d5; color:#9a6a00; }

/* segmented / toggle */
.adm-seg{ display:inline-flex; background:var(--surface-muted); border-radius:var(--radius-pill); padding:3px; gap:2px; }
.adm-seg button{ border:0; background:none; font-family:var(--font-mono); font-size:var(--fs-xs); letter-spacing:.06em; text-transform:uppercase; color:var(--text-muted); padding:.4rem .8rem; border-radius:var(--radius-pill); cursor:pointer; }
.adm-seg button.on{ background:var(--surface); color:var(--text); box-shadow:var(--shadow-card); }
.adm-switch{ width:42px; height:24px; border-radius:var(--radius-pill); background:var(--ink-300); border:0; position:relative; cursor:pointer; transition:background var(--dur-fast); flex:none; }
.adm-switch.on{ background:var(--accent); }
.adm-switch::after{ content:""; position:absolute; top:3px; left:3px; width:18px; height:18px; border-radius:50%; background:#fff; transition:transform var(--dur-fast) var(--ease-out); }
.adm-switch.on::after{ transform:translateX(18px); }

/* ---------- TABLE ---------- */
.adm-table{ width:100%; border-collapse:collapse; font-size:var(--fs-sm); }
.adm-table th{ text-align:left; font-family:var(--font-mono); font-size:var(--fs-xs); letter-spacing:.1em; text-transform:uppercase; color:var(--text-muted); font-weight:500; padding:.7rem .8rem; border-bottom:1px solid var(--border); }
.adm-table td{ padding:.85rem .8rem; border-bottom:1px solid var(--border-faint); vertical-align:middle; }
.adm-table tr:hover td{ background:var(--surface-muted); }
.adm-table .ti{ font-weight:500; color:var(--text); }
.adm-row-actions{ display:flex; gap:.4rem; justify-content:flex-end; }
.adm-iconbtn{ width:30px; height:30px; border-radius:var(--radius-sm); border:1px solid var(--border); background:var(--surface); cursor:pointer; color:var(--text-muted); display:grid; place-items:center; }
.adm-iconbtn:hover{ border-color:var(--border-strong); color:var(--text); }

/* ---------- APPEARANCE PICKERS ---------- */
.tpl-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:var(--space-4); }
.tpl-card{ border:1px solid var(--border); border-radius:var(--radius); padding:var(--space-3); cursor:pointer; background:var(--surface); transition:border-color var(--dur-fast), box-shadow var(--dur-fast); text-align:left; }
.tpl-card:hover{ border-color:var(--border-strong); }
.tpl-card.on{ border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-tint); }
.tpl-card__name{ font-weight:600; font-size:var(--fs-sm); display:flex; align-items:center; justify-content:space-between; }
.tpl-card__desc{ font-size:var(--fs-xs); color:var(--text-muted); margin-top:.2rem; }
.tpl-mini{ height:46px; border:1px solid var(--border-faint); border-radius:6px; margin-bottom:.6rem; display:flex; align-items:center; gap:4px; padding:0 7px; background:var(--bg); }
.tpl-mini .m-logo{ width:22px; height:7px; border-radius:2px; background:var(--text); }
.tpl-mini .m-nav{ flex:1; display:flex; gap:4px; }
.tpl-mini .m-nav i{ width:14px; height:4px; border-radius:2px; background:var(--ink-300); display:block; }
.tpl-mini .m-cta{ width:20px; height:10px; border-radius:5px; background:var(--accent); }
.tpl-mini.center{ flex-direction:column; justify-content:center; gap:3px; padding:5px 0; }
.tpl-mini.center .m-row{ display:flex; gap:4px; align-items:center; }

.swatches{ display:flex; gap:.6rem; flex-wrap:wrap; }
.swatch{ width:38px; height:38px; border-radius:var(--radius-sm); cursor:pointer; border:2px solid transparent; position:relative; }
.swatch.on{ border-color:var(--text); }
.swatch.on::after{ content:"✓"; position:absolute; inset:0; display:grid; place-items:center; color:#fff; font-size:13px; mix-blend-mode:difference; }

.font-list{ display:flex; flex-direction:column; gap:.5rem; }
.font-opt{ display:flex; align-items:center; justify-content:space-between; padding:.7rem .9rem; border:1px solid var(--border); border-radius:var(--radius-sm); cursor:pointer; background:var(--surface); }
.font-opt.on{ border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-tint); }
.font-opt .nm{ font-weight:600; }

.adm-preview{ border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; background:var(--surface-muted); }
.adm-preview__bar{ display:flex; align-items:center; gap:.5rem; padding:.6rem .9rem; border-bottom:1px solid var(--border); font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); }
.adm-preview__dot{ width:9px; height:9px; border-radius:50%; background:var(--ink-300); }
.adm-preview iframe{ width:100%; height:520px; border:0; display:block; background:#fff; }

/* ---------- AI ---------- */
.ai-panel{ background:linear-gradient(180deg, var(--accent-tint), transparent); border:1px solid var(--border); border-radius:var(--radius-lg); padding:var(--space-5); }
.ai-row{ display:flex; gap:.6rem; align-items:flex-end; }
.ai-out{ margin-top:var(--space-4); background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:var(--space-4); font-size:var(--fs-sm); line-height:1.7; white-space:pre-wrap; min-height:60px; }
.ai-spinner{ width:15px; height:15px; border:2px solid var(--on-accent); border-top-color:transparent; border-radius:50%; display:inline-block; animation:adm-spin .7s linear infinite; }
@keyframes adm-spin{ to{ transform:rotate(360deg); } }
.ai-chip{ font-family:var(--font-mono); font-size:10px; letter-spacing:.12em; text-transform:uppercase; color:var(--green-700); background:var(--accent-tint); padding:.3em .6em; border-radius:var(--radius-pill); display:inline-flex; align-items:center; gap:.4ch; }

/* ---------- MODAL ---------- */
.adm-modal__scrim{ position:fixed; inset:0; background:rgba(10,10,10,.45); -webkit-backdrop-filter:blur(3px); backdrop-filter:blur(3px); z-index:200; display:grid; place-items:center; padding:var(--space-5); }
.adm-modal{ background:var(--bg); border-radius:var(--radius-xl); width:min(720px,100%); max-height:88vh; overflow:auto; box-shadow:var(--shadow-pop); }
.adm-modal__h{ display:flex; align-items:center; justify-content:space-between; padding:var(--space-5); border-bottom:1px solid var(--border); position:sticky; top:0; background:var(--bg); }
.adm-modal__h h3{ font-size:1.1rem; font-weight:600; }
.adm-modal__b{ padding:var(--space-5); }
.adm-modal__f{ display:flex; justify-content:flex-end; gap:.6rem; padding:var(--space-5); border-top:1px solid var(--border); position:sticky; bottom:0; background:var(--bg); }

.adm-empty{ border:1px dashed var(--border); border-radius:var(--radius-lg); padding:var(--space-9); text-align:center; color:var(--text-muted); }
.adm-empty h3{ color:var(--text); font-size:1.1rem; margin-bottom:.5rem; }
.adm-skeleton-note{ display:inline-flex; align-items:center; gap:.5ch; font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); background:var(--surface-muted); padding:.4em .7em; border-radius:var(--radius-pill); margin-top:var(--space-4); }

.adm-mobilebar{ display:none; }
@media (max-width:1024px){
  .adm{ grid-template-columns:1fr; }
  .adm-side{ position:fixed; left:0; top:0; z-index:300; transform:translateX(-100%); transition:transform var(--dur) var(--ease-out); width:264px; }
  .adm.menu-open .adm-side{ transform:none; }
  .adm-mobilebar{ display:flex; align-items:center; gap:.8rem; padding:var(--space-4); border-bottom:1px solid var(--border); position:sticky; top:0; background:var(--bg); z-index:20; }
  .adm-grid--4{ grid-template-columns:repeat(2,1fr); }
  .adm-grid--3, .adm-grid--2{ grid-template-columns:1fr; }
  .tpl-grid{ grid-template-columns:1fr; }
}

/* ======================= EDITORS (blog / project) ======================= */
.editor{ display:grid; grid-template-columns:minmax(0,1fr) minmax(0,1fr); gap:var(--space-6); align-items:start; }
.editor__form{ display:flex; flex-direction:column; gap:var(--space-4); }
.editor__preview{ position:sticky; top:96px; }
.ed-toolbar{ display:flex; align-items:center; gap:.6rem; margin-bottom:var(--space-5); flex-wrap:wrap; }
.ed-toolbar .sp{ flex:1; }
.ed-back{ display:inline-flex; align-items:center; gap:.4ch; background:none; border:0; color:var(--text-muted); cursor:pointer; font-family:var(--font-sans); font-size:var(--fs-sm); }
.ed-back:hover{ color:var(--text); }

/* form sections + impact metrics repeater */
.ed-section{ display:flex; flex-direction:column; gap:var(--space-4); padding-bottom:var(--space-5); border-bottom:1px solid var(--border); }
.ed-section:last-child{ border-bottom:0; padding-bottom:0; }
.ed-section__h{ display:flex; align-items:baseline; gap:.6rem; }
.ed-section__h h4{ font-size:var(--fs-body); font-weight:600; }
.ed-section__h span{ font-size:var(--fs-xs); color:var(--text-muted); }
.metrics{ display:flex; flex-direction:column; gap:.5rem; }
.metrics__head, .metrics__row{ display:grid; grid-template-columns:1.6fr 1fr 1fr 36px; gap:.5rem; align-items:center; }
.metrics__head{ font-family:var(--font-mono); font-size:10px; letter-spacing:.08em; text-transform:uppercase; color:var(--text-muted); padding:0 .2rem; }
.metrics__row .adm-input{ padding:.5rem .7rem; }

/* image upload */
.img-up{ position:relative; border:1.5px dashed var(--border); border-radius:var(--radius); overflow:hidden; cursor:pointer; background:var(--surface-muted); display:grid; place-items:center; transition:border-color var(--dur-fast), background var(--dur-fast); width:100%; }
.img-up:hover{ border-color:var(--accent); background:var(--accent-tint); }
.img-up.has{ border-style:solid; border-color:var(--border); background:var(--surface); }
.img-up.drag{ border-color:var(--accent); background:var(--accent-tint); }
.img-up img{ width:100%; height:100%; object-fit:cover; display:block; }
.img-up__ph{ display:flex; flex-direction:column; align-items:center; gap:.4rem; color:var(--text-muted); font-size:var(--fs-sm); padding:1.2rem; text-align:center; }
.img-up__x{ position:absolute; top:8px; right:8px; width:28px; height:28px; border-radius:50%; border:0; background:rgba(10,10,10,.6); color:#fff; cursor:pointer; display:grid; place-items:center; z-index:2; }

/* gallery uploader */
.gal-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:.7rem; }
.gal-item .img-up{ aspect-ratio:1/1; }
.gal-cap{ width:100%; margin-top:.35rem; font-size:var(--fs-xs); border:0; border-bottom:1px solid var(--border); background:none; padding:.3rem 0; font-family:var(--font-sans); color:var(--text); }
.gal-cap:focus{ outline:none; border-bottom-color:var(--accent); }

/* repeatable blocks (Q&A, list) */
.blk{ border:1px solid var(--border); border-radius:var(--radius-sm); padding:var(--space-3); margin-bottom:.7rem; display:flex; flex-direction:column; gap:.5rem; position:relative; }
.blk__x{ position:absolute; top:8px; right:8px; width:24px; height:24px; border-radius:var(--radius-xs); border:1px solid var(--border); background:var(--surface); cursor:pointer; color:var(--text-muted); }
.blk-add{ align-self:flex-start; }

/* template picker (big cards) */
.btpl-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-4); }
.btpl{ text-align:left; border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; cursor:pointer; background:var(--surface); transition:border-color var(--dur-fast), box-shadow var(--dur-fast), transform var(--dur-fast); }
.btpl:hover{ border-color:var(--border-strong); transform:translateY(-3px); }
.btpl.on{ border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-tint); }
.btpl__vis{ height:120px; background:var(--surface-muted); border-bottom:1px solid var(--border); padding:12px; display:flex; flex-direction:column; gap:5px; }
.btpl__vis i, .btpl__vis b{ display:block; border-radius:3px; }
.btpl__vis .bar{ height:6px; background:var(--ink-300); }
.btpl__vis .img{ background:var(--accent); opacity:.5; border-radius:5px; flex:1; }
.btpl__vis .row{ display:flex; gap:5px; flex:1; }
.btpl__b{ padding:var(--space-4); }
.btpl__b h4{ font-size:var(--fs-sm); font-weight:600; }
.btpl__b p{ font-size:var(--fs-xs); color:var(--text-muted); margin-top:.25rem; }

/* live article/project preview */
.prev-frame{ border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; background:var(--bg); }
.prev-frame__bar{ display:flex; align-items:center; gap:.5rem; padding:.55rem .9rem; border-bottom:1px solid var(--border); font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); }
.prev-scroll{ max-height:calc(100vh - 200px); overflow:auto; }
.pv{ padding:var(--space-6); display:flex; flex-direction:column; gap:var(--space-4); }
.pv__cover{ aspect-ratio:21/9; border-radius:var(--radius-lg); overflow:hidden; background:var(--surface-muted); }
.pv__cover img{ width:100%; height:100%; object-fit:cover; }
.pv .kicker{ font-family:var(--font-mono); font-size:var(--fs-label); letter-spacing:.14em; text-transform:uppercase; color:var(--accent-hover); }
.pv h1{ font-size:clamp(1.7rem,3.2vw,2.6rem); letter-spacing:-0.025em; line-height:1.04; font-weight:600; }
.pv .lead{ font-size:1.1rem; color:var(--text-muted); line-height:1.6; }
.pv p{ line-height:1.75; }
.pv h2{ font-size:1.3rem; font-weight:600; margin-top:.5rem; }
.pv img.inl{ width:100%; border-radius:var(--radius); display:block; }
.pv figure{ margin:0; }
.pv figcaption{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); margin-top:.4rem; }
.pv__gal{ display:grid; grid-template-columns:1fr 1fr; gap:.8rem; }
.pv__gal img{ width:100%; aspect-ratio:4/3; object-fit:cover; border-radius:var(--radius); }
.pv__qa{ border-left:2px solid var(--accent); padding-left:1rem; display:flex; flex-direction:column; gap:.3rem; }
.pv__qa .q{ font-weight:600; }
.pv__qa .a{ color:var(--text-muted); }
.pv__meta{ display:grid; grid-template-columns:repeat(2,1fr); gap:1rem; border-block:1px solid var(--border); padding:1.1rem 0; }
.pv__meta dt{ font-family:var(--font-mono); font-size:10px; letter-spacing:.1em; text-transform:uppercase; color:var(--text-muted); margin-bottom:.25rem; }
.pv__meta dd{ margin:0; font-weight:500; }
.pv__step{ display:flex; gap:1rem; }
.pv__step .n{ font-family:var(--font-mono); color:var(--accent-hover); font-weight:600; }
/* case-study preview blocks */
.pv__block{ display:flex; flex-direction:column; gap:.6rem; }
.pv__metrics{ display:grid; grid-template-columns:1fr; gap:.6rem; border-block:1px solid var(--border); padding:1.1rem 0; }
.pv__metric{ display:flex; align-items:center; justify-content:space-between; gap:1rem; }
.pv__metric-lbl{ font-size:var(--fs-sm); color:var(--text-muted); }
.pv__metric-val{ display:flex; align-items:center; gap:.6rem; font-family:var(--font-mono); }
.pv__metric-val .b{ color:var(--text-subtle); text-decoration:line-through; text-decoration-thickness:1px; }
.pv__metric-val .ar{ color:var(--accent); }
.pv__metric-val .a{ color:var(--text); font-weight:600; font-size:1.05rem; }
.pv__quote{ margin:0; border-left:3px solid var(--accent); padding:.4rem 0 .4rem 1.1rem; }
.pv__quote p{ font-size:1.15rem; line-height:1.5; font-style:italic; }
.pv__quote footer{ margin-top:.6rem; font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); font-style:normal; }
.pv__placeholder{ width:100%; aspect-ratio:16/9; border-radius:var(--radius); background:repeating-linear-gradient(45deg,var(--surface-muted),var(--surface-muted) 10px,var(--bg) 10px,var(--bg) 20px); display:grid; place-items:center; color:var(--text-subtle); font-family:var(--font-mono); font-size:var(--fs-xs); }

@media (max-width:1024px){
  .editor{ grid-template-columns:1fr; }
  .editor__preview{ position:static; }
  .btpl-grid{ grid-template-columns:1fr; }
  .gal-grid{ grid-template-columns:1fr 1fr; }
}

/* ======================= SETTINGS ======================= */
.set{ display:grid; grid-template-columns:230px 1fr; gap:var(--space-6); align-items:start; }
.set-nav{ display:flex; flex-direction:column; gap:2px; position:sticky; top:96px; }
.set-nav button{ display:flex; align-items:center; gap:.6rem; text-align:left; background:none; border:0; padding:.65rem .8rem; border-radius:var(--radius-sm); cursor:pointer; color:var(--text-muted); font-family:inherit; font-size:.92rem; }
.set-nav button:hover{ background:var(--surface-muted); color:var(--text); }
.set-nav button.on{ background:var(--accent-tint); color:var(--green-700); font-weight:600; }
.set-stack{ display:flex; flex-direction:column; gap:var(--space-5); }
.set-row{ display:grid; grid-template-columns:1fr 1fr; gap:var(--space-4); }
.set-logos{ display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-4); }
.set-logo{ display:flex; flex-direction:column; gap:.5rem; }
.set-logo .img-up{ aspect-ratio:1/1; }
.set-logo .img-up.wide{ aspect-ratio:16/6; }
.set-logo small{ font-size:var(--fs-xs); color:var(--text-muted); }
.key-input{ position:relative; display:flex; gap:.5rem; }
.key-input input{ flex:1; }
.range-row{ display:flex; align-items:center; gap:1rem; }
.range-row output{ font-family:var(--font-mono); font-size:var(--fs-sm); color:var(--text-muted); min-width:46px; }
.set-save{ position:sticky; bottom:0; display:flex; align-items:center; justify-content:flex-end; gap:.6rem; padding:var(--space-4) 0 0; margin-top:var(--space-2); border-top:1px solid var(--border); background:linear-gradient(transparent, var(--bg) 40%); }
.set-save .hint{ margin-right:auto; font-size:var(--fs-xs); color:var(--text-muted); font-family:var(--font-mono); }
.set-toast{ position:fixed; bottom:24px; left:50%; transform:translateX(-50%); background:var(--ink-900); color:#fff; padding:.7rem 1.2rem; border-radius:var(--radius-pill); font-size:var(--fs-sm); z-index:400; box-shadow:var(--shadow-pop); display:flex; align-items:center; gap:.5ch; }
.set-toast .ok{ color:var(--accent); }
.danger{ border:1px solid color-mix(in srgb, var(--signal-err) 50%, var(--border)); border-radius:var(--radius-lg); padding:var(--space-5); display:flex; align-items:center; justify-content:space-between; gap:var(--space-4); flex-wrap:wrap; }
.danger h4{ color:var(--signal-err); font-size:var(--fs-sm); }
.danger p{ font-size:var(--fs-xs); color:var(--text-muted); }
.adm-btn--danger{ background:var(--signal-err); color:#fff; }
.conn-ok{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--green-700); display:inline-flex; align-items:center; gap:.4ch; }
@media (max-width:1024px){
  .set{ grid-template-columns:1fr; }
  .set-nav{ position:static; flex-direction:row; flex-wrap:wrap; }
  .set-logos{ grid-template-columns:1fr 1fr; }
  .set-row{ grid-template-columns:1fr; }
}

/* ======================= CUSTOM SELECT POPUP ======================= */
.mk-select{ position:relative; display:inline-block; width:100%; }
.mk-select__btn{ width:100%; display:flex; align-items:center; justify-content:space-between; gap:.5rem; font-family:var(--font-sans); font-size:var(--fs-body); color:var(--text); background:var(--bg); border:1px solid var(--border); border-radius:var(--radius-sm); padding:.7rem .85rem; cursor:pointer; transition:border-color var(--dur-fast), box-shadow var(--dur-fast); text-align:left; }
.mk-select__btn:hover{ border-color:var(--border-strong); }
.mk-select.open .mk-select__btn{ border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-tint); }
.mk-select__val.placeholder{ color:var(--text-subtle); }
.mk-select__chev{ transition:transform var(--dur-fast) var(--ease-out); color:var(--text-muted); flex:none; font-size:11px; }
.mk-select.open .mk-select__chev{ transform:rotate(180deg); }
.mk-select__pop{ position:absolute; top:calc(100% + 6px); left:0; right:0; z-index:140; background:var(--bg-elevated); border:1px solid var(--border); border-radius:var(--radius); box-shadow:var(--shadow-pop); padding:6px; max-height:300px; overflow:auto; animation:mk-sel-in .16s var(--ease-out); }
.mk-select__pop.up{ top:auto; bottom:calc(100% + 6px); }
@keyframes mk-sel-in{ from{ opacity:0; transform:translateY(-6px); } to{ opacity:1; transform:none; } }
.mk-select__opt{ width:100%; display:flex; align-items:center; justify-content:space-between; gap:.5rem; text-align:left; background:none; border:0; font-family:inherit; font-size:var(--fs-sm); color:var(--text); padding:.55rem .6rem; border-radius:var(--radius-xs); cursor:pointer; }
.mk-select__opt:hover{ background:var(--surface-muted); }
.mk-select__opt.on{ color:var(--accent-hover); font-weight:600; background:var(--accent-tint); }
.mk-select__opt .ck{ color:var(--accent); }
.mk-select__group{ font-family:var(--font-mono); font-size:10px; letter-spacing:.1em; text-transform:uppercase; color:var(--text-muted); padding:.5rem .6rem .25rem; }
.mk-select__opt.is-sub{ padding-left:.9rem; }
.mk-select__opt:has(.mk-select__box){ justify-content:flex-start; }
.mk-select__box{ width:17px; height:17px; flex:none; border:1.5px solid var(--border-strong); border-radius:var(--radius-xs); display:grid; place-items:center; color:#fff; transition:background var(--dur-fast), border-color var(--dur-fast); }
.mk-select__box.on{ background:var(--accent); border-color:var(--accent); }
.mk-select__search{ width:100%; border:1px solid var(--border); border-radius:var(--radius-xs); padding:.5rem .6rem; font-family:var(--font-sans); font-size:var(--fs-sm); margin-bottom:4px; outline:none; background:var(--bg); color:var(--text); position:sticky; top:0; }
.mk-select__search:focus{ border-color:var(--accent); }
.mk-select__empty{ padding:.6rem; font-size:var(--fs-sm); color:var(--text-muted); text-align:center; }

/* ======================= RIGHT DRAWER ======================= */
.drawer-scrim{ position:fixed; inset:0; background:rgba(10,10,10,.42); -webkit-backdrop-filter:blur(2px); backdrop-filter:blur(2px); z-index:300; opacity:0; animation:dscrim .25s ease forwards; }
@keyframes dscrim{ to{ opacity:1; } }
.drawer{ position:fixed; top:0; right:0; height:100vh; width:min(480px,100%); background:var(--bg); z-index:301; box-shadow:var(--shadow-pop); display:flex; flex-direction:column; transform:translateX(100%); animation:dslide .34s var(--ease-out) forwards; }
@keyframes dslide{ to{ transform:none; } }
.drawer__h{ display:flex; align-items:center; justify-content:space-between; padding:var(--space-5); border-bottom:1px solid var(--border); }
.drawer__h h3{ font-size:1.05rem; font-weight:600; }
.drawer__h p{ font-size:var(--fs-xs); color:var(--text-muted); }
.drawer__b{ padding:var(--space-5); overflow-y:auto; flex:1; display:flex; flex-direction:column; gap:var(--space-4); }
.drawer__f{ display:flex; gap:.6rem; justify-content:flex-end; padding:var(--space-5); border-top:1px solid var(--border); background:var(--bg); }
.drawer__avatar{ display:flex; align-items:center; gap:var(--space-4); }
.drawer__avatar .img-up{ width:88px; height:88px; border-radius:50%; flex:none; aspect-ratio:1/1; }
.drawer__avatar .img-up img{ border-radius:50%; }

/* ======================= TABS (users/seo) ======================= */
.tabs{ display:inline-flex; gap:2px; background:var(--surface-muted); padding:3px; border-radius:var(--radius-pill); margin-bottom:var(--space-5); }
.tabs button{ border:0; background:none; font-family:var(--font-sans); font-size:var(--fs-sm); color:var(--text-muted); padding:.5rem 1.1rem; border-radius:var(--radius-pill); cursor:pointer; }
.tabs button.on{ background:var(--surface); color:var(--text); box-shadow:var(--shadow-card); font-weight:500; }
.avatar-cell{ display:flex; align-items:center; gap:.7rem; }
.avatar-cell .av{ width:34px; height:34px; border-radius:50%; background:var(--accent); color:var(--on-accent); display:grid; place-items:center; font-family:var(--font-mono); font-weight:600; font-size:.72rem; overflow:hidden; flex:none; }
.avatar-cell .av img{ width:100%; height:100%; object-fit:cover; }

/* permissions matrix */
.perm-group{ border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; margin-bottom:var(--space-4); }
.perm-group__h{ display:flex; align-items:center; justify-content:space-between; padding:.7rem 1rem; background:var(--surface-muted); font-weight:600; font-size:var(--fs-sm); }
.perm-row{ display:flex; align-items:center; justify-content:space-between; padding:.6rem 1rem; border-top:1px solid var(--border-faint); font-size:var(--fs-sm); }
.perm-row .pl{ color:var(--text); }
.perm-row .pd{ color:var(--text-muted); font-size:var(--fs-xs); }
.role-card{ display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:var(--space-4); border:1px solid var(--border); border-radius:var(--radius); margin-bottom:.6rem; }
.role-card b{ font-weight:600; }
.role-card__meta{ font-size:var(--fs-xs); color:var(--text-muted); font-family:var(--font-mono); margin-top:.2rem; }

/* appearance live preview — sticky */
.appr-preview{ position:sticky; top:90px; align-self:start; }
@media (max-width:1024px){ .appr-preview{ position:static; } }

/* ======================= MEDIA LIBRARY ======================= */
.media{ display:grid; grid-template-columns:230px 1fr; gap:var(--space-5); align-items:start; }
.media-side{ display:flex; flex-direction:column; gap:2px; position:sticky; top:96px; }
.media-side__lbl{ font-family:var(--font-mono); font-size:10px; letter-spacing:.14em; text-transform:uppercase; color:var(--text-muted); padding:.8rem .6rem .4rem; }
.media-fld{ display:flex; align-items:center; gap:.6rem; width:100%; text-align:left; background:none; border:0; padding:.6rem; border-radius:var(--radius-sm); cursor:pointer; color:var(--text); font-family:inherit; font-size:.9rem; transition:background var(--dur-fast); }
.media-fld:hover{ background:var(--surface-muted); }
.media-fld.on{ background:var(--accent-tint); color:var(--green-700); font-weight:500; }
.media-fld .c{ margin-left:auto; font-family:var(--font-mono); font-size:11px; color:var(--text-muted); }
.media-fld.on .c{ color:var(--green-700); }
.media-fld--add{ color:var(--text-muted); }
.media-fld__tw{ width:14px; flex:none; font-size:10px; color:var(--text-muted); display:inline-flex; justify-content:center; cursor:pointer; }
.media-fld__nm{ overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.media-crumb{ display:flex; align-items:center; gap:.4rem; flex-wrap:wrap; margin-bottom:var(--space-2); font-size:var(--fs-sm); }
.media-crumb button{ background:none; border:0; color:var(--text-muted); cursor:pointer; font-family:inherit; font-size:var(--fs-sm); padding:.1rem .2rem; border-radius:var(--radius-xs); }
.media-crumb button:hover{ color:var(--text); }
.media-crumb button.on{ color:var(--text); font-weight:600; }
.media-crumb .sep{ color:var(--text-subtle); }
.folder-card{ text-align:left; background:var(--surface-muted); border:1px solid var(--border); border-radius:var(--radius); padding:14px; cursor:pointer; transition:border-color var(--dur-fast), transform var(--dur-fast); display:flex; flex-direction:column; gap:8px; }
.folder-card:hover{ border-color:var(--accent); transform:translateY(-2px); }
.folder-card__ic{ width:46px; height:46px; border-radius:var(--radius-sm); background:var(--accent-tint); color:var(--green-700); display:grid; place-items:center; }

/* ======================= IMAGE PICKER POPUP ======================= */
.pick-import{ display:flex; flex-direction:column; align-items:center; gap:.45rem; width:100%; padding:var(--space-7); border:1.5px dashed var(--border); border-radius:var(--radius-lg); background:var(--surface-muted); cursor:pointer; color:var(--text); text-align:center; transition:border-color var(--dur-fast), background var(--dur-fast); }
.pick-import:hover, .pick-import.drag{ border-color:var(--accent); background:var(--accent-tint); }
.pick-import .pi-ic{ width:46px; height:46px; border-radius:50%; background:var(--accent); color:var(--on-accent); display:grid; place-items:center; }
.pick-import b{ font-weight:600; }
.pick-import small{ color:var(--text-muted); font-size:var(--fs-xs); }
.pick-sep{ display:flex; align-items:center; gap:1rem; color:var(--text-muted); font-size:var(--fs-sm); margin:var(--space-5) 0 var(--space-4); }
.pick-sep::before, .pick-sep::after{ content:""; flex:1; height:1px; background:var(--border); }
.pick-search{ display:flex; align-items:center; gap:.5rem; border:1px solid var(--border); border-radius:var(--radius-pill); padding:.5rem .9rem; color:var(--text-muted); }
.pick-search input{ border:0; outline:none; background:none; width:100%; font-family:inherit; font-size:var(--fs-sm); color:var(--text); }

/* organized library browser inside the picker */
.pick-lib{ border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; background:var(--surface); }
.pick-lib__bar{ display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; padding:.7rem .9rem; border-bottom:1px solid var(--border); background:var(--surface-muted); }
.pick-lib__bar .pick-search{ margin:0; background:var(--surface); min-width:200px; }
.pick-scroll{ max-height:340px; overflow-y:auto; padding:var(--space-4); }
.pick-folders{ display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:.6rem; margin-bottom:var(--space-4); }
.pick-folder{ display:flex; align-items:center; gap:.6rem; text-align:left; background:var(--surface-muted); border:1px solid var(--border); border-radius:var(--radius); padding:.7rem .8rem; cursor:pointer; transition:border-color var(--dur-fast), transform var(--dur-fast); }
.pick-folder:hover{ border-color:var(--accent); transform:translateY(-1px); }
.pick-folder__ic{ width:32px; height:32px; flex:none; border-radius:var(--radius-sm); background:var(--accent-tint); color:var(--green-700); display:grid; place-items:center; }
.pick-folder__nm{ flex:1; font-size:var(--fs-sm); font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.pick-folder__ct{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); }
.file-card__loc{ display:flex; align-items:center; gap:.35ch; font-size:10px; color:var(--text-muted); font-family:var(--font-mono); margin-top:2px; }
.file-card__loc svg{ color:var(--green-700); }

/* ======================= SERVICES (admin) ======================= */
.svc-groups{ display:flex; flex-direction:column; gap:var(--space-6); }
.svc-group{ display:flex; flex-direction:column; gap:var(--space-4); }
.svc-group:not(:last-child){ padding-bottom:var(--space-6); border-bottom:1px solid var(--border); }
.svc-group__h{ display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
.svc-group__title{ display:flex; align-items:flex-start; gap:.6rem; }
.svc-group__title h3{ font-size:1.05rem; font-weight:600; letter-spacing:-0.01em; }
.svc-group__count{ font-family:var(--font-mono); font-size:var(--fs-xs); font-weight:400; color:var(--text-muted); margin-left:.4rem; }
.svc-group__title p{ font-size:var(--fs-sm); color:var(--text-muted); margin-top:.2rem; }
.svc-group__title .svc-dot{ margin-top:.45rem; }
.svc-group__actions{ display:flex; align-items:center; gap:.4rem; }
.svc-empty{ display:flex; align-items:center; justify-content:center; gap:.5ch; padding:var(--space-5); border:1.5px dashed var(--border); border-radius:var(--radius); background:var(--surface-muted); color:var(--text-muted); cursor:pointer; font-family:inherit; font-size:var(--fs-sm); transition:border-color var(--dur-fast), color var(--dur-fast); }
.svc-empty:hover{ border-color:var(--accent); color:var(--accent-hover); }
.svc-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:var(--space-4); }

/* ======================= PAGES / SECTION MANAGER ======================= */
.seclist{ list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:.5rem; }
.seclist__row{ display:flex; align-items:center; gap:.8rem; padding:.7rem .8rem; border:1px solid var(--border); border-radius:var(--radius); background:var(--surface); transition:opacity var(--dur-fast); }
.seclist__row.is-hidden{ opacity:.5; }
.seclist__order{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); width:22px; flex:none; }
.seclist__ic{ display:grid; place-items:center; width:32px; height:32px; flex:none; border-radius:8px; background:var(--surface-muted); color:var(--text-muted); }
.seclist__ic.is-custom{ background:var(--accent-tint); color:var(--green-700); }
.seclist__meta{ flex:1; min-width:0; display:flex; flex-direction:column; }
.seclist__meta b{ font-weight:500; font-size:var(--fs-sm); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.seclist__meta span{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); }
.seclist__actions{ display:flex; align-items:center; gap:.3rem; flex:none; }
.seclist__hint{ display:flex; align-items:center; gap:.5ch; margin-top:var(--space-4); font-size:var(--fs-xs); color:var(--text-muted); }
.seclist__hint svg{ color:var(--green-700); flex:none; }
.addsec-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-3); }
.addsec{ display:flex; flex-direction:column; align-items:flex-start; gap:.4rem; text-align:left; padding:var(--space-4); border:1px solid var(--border); border-radius:var(--radius); background:var(--surface); cursor:pointer; transition:border-color var(--dur-fast), transform var(--dur-fast); }
.addsec:hover{ border-color:var(--accent); transform:translateY(-2px); }
.addsec__ic{ display:grid; place-items:center; width:42px; height:42px; border-radius:10px; background:var(--accent-tint); color:var(--green-700); margin-bottom:.3rem; }
.addsec b{ font-size:var(--fs-sm); font-weight:600; }
.addsec span{ font-size:var(--fs-xs); color:var(--text-muted); }
@media (max-width:560px){ .addsec-grid{ grid-template-columns:1fr; } }

/* ======================= CURRICULUM / LISTS / SPECS (editors) ======================= */
.curr{ display:flex; flex-direction:column; gap:var(--space-3); }
.curr-mod{ border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
.curr-mod__h{ display:flex; align-items:center; gap:.6rem; padding:.6rem .7rem; background:var(--surface-muted); }
.curr-mod__n{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); flex:none; }
.curr-mod__c{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); white-space:nowrap; }
.curr-lessons{ display:flex; flex-direction:column; gap:.4rem; padding:.6rem .7rem; }
.curr-lesson{ display:flex; align-items:center; gap:.5rem; }
.curr-lesson__ic{ color:var(--text-subtle); flex:none; }
.curr-lesson__dur{ width:80px; flex:none; text-align:center; font-family:var(--font-mono); }
.curr-lesson__caret{ display:grid; place-items:center; width:24px; height:24px; flex:none; border:0; background:none; color:var(--text-muted); cursor:pointer; border-radius:6px; transition:transform var(--dur-fast), background var(--dur-fast); }
.curr-lesson__caret:hover{ background:var(--surface-muted); }
.curr-lesson-wrap.open .curr-lesson__caret{ transform:rotate(180deg); color:var(--accent-hover); }
.curr-lesson__type{ display:grid; place-items:center; width:26px; height:26px; flex:none; border-radius:7px; background:var(--accent-tint); color:var(--green-700); }
.curr-lesson-wrap{ border:1px solid transparent; border-radius:var(--radius); transition:border-color var(--dur-fast); }
.curr-lesson-wrap.open{ border-color:var(--border); background:var(--surface); }
.curr-lesson-wrap.open .curr-lesson{ padding:.3rem .4rem; }
.lesson-body{ display:flex; flex-direction:column; gap:var(--space-3); padding:0 .7rem .8rem 2.4rem; }
.lesson-free{ display:flex; align-items:center; gap:.6rem; font-size:var(--fs-sm); color:var(--text-muted); cursor:pointer; }
.seg{ display:inline-flex; gap:4px; padding:3px; background:var(--surface-muted); border-radius:var(--radius-sm); }
.seg--wrap{ display:flex; flex-wrap:wrap; }
.seg__btn{ display:inline-flex; align-items:center; gap:.4ch; padding:.35rem .7rem; border:0; background:none; border-radius:calc(var(--radius-sm) - 3px); font-family:inherit; font-size:var(--fs-xs); color:var(--text-muted); cursor:pointer; white-space:nowrap; transition:background var(--dur-fast), color var(--dur-fast); }
.seg__btn.on{ background:var(--surface); color:var(--text); box-shadow:var(--shadow-1); font-weight:500; }
.file-drop{ display:flex; flex-direction:column; align-items:center; justify-content:center; gap:.4rem; padding:var(--space-5); border:1.5px dashed var(--border); border-radius:var(--radius); background:var(--surface-muted); color:var(--text-muted); cursor:pointer; font-size:var(--fs-sm); transition:border-color var(--dur-fast); }
.file-drop.drag,.file-drop:hover{ border-color:var(--accent); color:var(--accent-hover); }
.file-chip{ display:flex; align-items:center; gap:.7rem; padding:.6rem .8rem; border:1px solid var(--border); border-radius:var(--radius); background:var(--surface); }
.file-chip__ic{ display:grid; place-items:center; width:34px; height:34px; flex:none; border-radius:8px; background:var(--accent-tint); color:var(--green-700); }
.file-chip__meta{ flex:1; min-width:0; display:flex; flex-direction:column; }
.file-chip__meta b{ font-weight:500; font-size:var(--fs-sm); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.file-chip__meta span{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); }
.pv-free{ font-family:var(--font-mono); font-size:9px; text-transform:uppercase; letter-spacing:.08em; color:var(--green-700); background:var(--accent-tint); padding:1px 6px; border-radius:999px; margin-left:.5rem; }
.curr-addlesson{ display:inline-flex; align-items:center; gap:.4ch; align-self:flex-start; background:none; border:0; color:var(--accent-hover); cursor:pointer; font-family:inherit; font-size:var(--fs-sm); padding:.2rem 0; }
.blist{ display:flex; flex-direction:column; gap:.5rem; }
.blist__row{ display:flex; align-items:center; gap:.6rem; }
.blist__dot{ width:7px; height:7px; border-radius:50%; background:var(--accent); flex:none; }
.specs{ display:flex; flex-direction:column; gap:.5rem; }
.specs__row{ display:grid; grid-template-columns:1fr 1fr 36px; gap:.5rem; align-items:center; }

/* editor preview: course/product extras */
.pv-course__bar{ display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:1rem 0; border-block:1px solid var(--border); }
.pv-course__price{ display:flex; align-items:baseline; gap:.6rem; font-family:var(--font-mono); }
.pv-course__price .now{ font-size:1.5rem; font-weight:600; letter-spacing:-0.02em; }
.pv-course__price .was{ color:var(--text-subtle); text-decoration:line-through; font-size:1rem; }
.pv-checklist{ list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:.55rem; }
.pv-checklist li{ display:flex; gap:.6rem; align-items:flex-start; line-height:1.5; }
.pv-checklist .ck{ color:var(--accent); font-weight:700; flex:none; }
.pv-checklist--plain .ck{ color:var(--text-subtle); }
.pv-curr{ display:flex; flex-direction:column; gap:.5rem; }
.pv-curr__mod{ border:1px solid var(--border); border-radius:var(--radius); }
.pv-curr__mod summary{ display:flex; align-items:center; justify-content:space-between; gap:.6rem; padding:.7rem .9rem; cursor:pointer; font-weight:500; list-style:none; }
.pv-curr__mod summary::-webkit-details-marker{ display:none; }
.pv-curr__mod summary .c{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); }
.pv-curr__lesson{ display:flex; align-items:center; justify-content:space-between; gap:.6rem; padding:.5rem .9rem; border-top:1px solid var(--border); font-size:var(--fs-sm); color:var(--text-muted); }
.pv-curr__lesson .ic{ color:var(--accent); font-size:10px; }
.pv-curr__lesson .d{ font-family:var(--font-mono); font-size:var(--fs-xs); }
.pv-specs{ display:grid; grid-template-columns:1fr; gap:0; margin:0; }
.pv-specs > div{ display:flex; justify-content:space-between; gap:1rem; padding:.55rem 0; border-bottom:1px solid var(--border); }
.pv-specs dt{ color:var(--text-muted); font-size:var(--fs-sm); }
.pv-specs dd{ margin:0; font-weight:500; font-family:var(--font-mono); font-size:var(--fs-sm); }
.svc-card{ display:flex; flex-direction:column; gap:.6rem; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:var(--space-4); }
.svc-card__top{ display:flex; align-items:center; gap:.6rem; }
.svc-card__top h4{ flex:1; font-size:var(--fs-body); font-weight:600; }
.svc-card__top .adm-row-actions{ opacity:0; transition:opacity var(--dur-fast); }
.svc-card:hover .adm-row-actions{ opacity:1; }
.svc-card p{ font-size:var(--fs-sm); color:var(--text-muted); line-height:1.5; flex:1; }
.svc-dot{ width:8px; height:8px; border-radius:50%; background:var(--text-subtle); flex:none; }
.svc-dot.on{ background:var(--accent); }

/* ======================= AI REPORT ======================= */
.rep{ display:flex; flex-direction:column; gap:var(--space-5); }
.rep-head{ display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
.rep-kicker{ display:inline-flex; align-items:center; gap:.5ch; font-family:var(--font-mono); font-size:var(--fs-xs); letter-spacing:.1em; text-transform:uppercase; color:var(--green-700); }
.rep-title{ font-size:1.6rem; font-weight:600; letter-spacing:-0.02em; margin:.2rem 0; }
.rep-date{ font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); }
.rep-chart{ display:flex; align-items:flex-end; gap:10px; height:170px; padding-top:18px; }
.rep-bar-col{ flex:1; display:flex; flex-direction:column; align-items:center; gap:6px; justify-content:flex-end; }
.rep-bar{ width:100%; max-width:42px; background:var(--accent); border-radius:6px 6px 0 0; }
.rep-bar-val{ font-family:var(--font-mono); font-size:10px; color:var(--text-muted); }
.rep-bar-day{ font-family:var(--font-mono); font-size:10px; color:var(--text-muted); }
.chan-row{ display:flex; flex-direction:column; gap:6px; }
.chan-top{ display:flex; justify-content:space-between; font-size:var(--fs-sm); }
.chan-top b{ font-family:var(--font-mono); font-weight:600; }
.chan-track{ height:8px; background:var(--surface-muted); border-radius:999px; overflow:hidden; }
.chan-fill{ height:100%; background:var(--accent); border-radius:999px; transition:width var(--dur-slow) var(--ease-out); }
.rep-doc{ display:flex; flex-direction:column; gap:.5rem; }
.rep-doc .rep-h{ font-size:1.05rem; font-weight:600; margin:.8rem 0 .2rem; }
.rep-doc .rep-h:first-child{ margin-top:0; }
.rep-doc .rep-p{ font-size:var(--fs-sm); line-height:1.7; color:var(--text); }
.rep-doc .rep-ul{ margin:.2rem 0; padding-left:0; list-style:none; display:flex; flex-direction:column; gap:.5rem; }
.rep-doc .rep-ul li{ position:relative; padding-left:1.4rem; font-size:var(--fs-sm); line-height:1.6; }
.rep-doc .rep-ul li::before{ content:""; position:absolute; left:2px; top:.55em; width:7px; height:7px; border-radius:50%; background:var(--accent); }

/* ======================= AI BLOG WIZARD ======================= */
.wiz-steps{ display:flex; align-items:center; gap:.4rem; }
.wiz-step{ display:inline-flex; align-items:center; gap:.5ch; font-size:var(--fs-xs); color:var(--text-muted); font-family:var(--font-mono); }
.wiz-step:not(:last-child)::after{ content:"›"; margin-left:.4rem; color:var(--text-subtle); }
.wiz-step.on{ color:var(--text); font-weight:600; }
.wiz-step__n{ width:20px; height:20px; border-radius:50%; border:1px solid var(--border); display:grid; place-items:center; font-size:10px; }
.wiz-step.on .wiz-step__n{ background:var(--accent); color:var(--on-accent); border-color:var(--accent); }
.wiz-step.done .wiz-step__n{ background:var(--accent-tint); color:var(--green-700); border-color:transparent; }
.wiz-chips{ display:flex; flex-direction:column; gap:.6rem; }
.wiz-chip{ display:flex; align-items:center; gap:.7ch; text-align:left; width:100%; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:.85rem 1rem; cursor:pointer; font-family:inherit; font-size:var(--fs-body); color:var(--text); transition:border-color var(--dur-fast), background var(--dur-fast); }
.wiz-chip:hover{ border-color:var(--accent); background:var(--accent-tint); }
.wiz-chip svg{ color:var(--green-700); flex:none; }
.media-newfld{ display:flex; gap:.4rem; padding:.3rem; }
.media-main{ min-width:0; display:flex; flex-direction:column; gap:var(--space-4); }
.media-bar{ display:flex; align-items:center; gap:var(--space-3); flex-wrap:wrap; }
.media-search{ display:flex; align-items:center; gap:.5rem; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-pill); padding:.45rem .8rem; color:var(--text-muted); margin-left:auto; }
.media-search input{ border:0; background:none; outline:none; font-family:inherit; font-size:var(--fs-sm); color:var(--text); width:160px; }
.media-drop{ border:1.5px dashed transparent; border-radius:var(--radius-lg); transition:border-color var(--dur-fast), background var(--dur-fast); min-height:200px; }
.media-drop.drag{ border-color:var(--accent); background:var(--accent-tint); }
.media-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:var(--space-4); }
.file-card{ text-align:left; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:8px; cursor:pointer; transition:border-color var(--dur-fast), box-shadow var(--dur-fast), transform var(--dur-fast); display:flex; flex-direction:column; gap:6px; }
.file-card:hover{ border-color:var(--border-strong); box-shadow:var(--shadow-card); transform:translateY(-2px); }
.file-card__nm{ font-size:var(--fs-sm); font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.file-card__meta{ font-family:var(--font-mono); font-size:10px; color:var(--text-muted); }
@media (max-width:1024px){
  .media{ grid-template-columns:1fr; }
  .media-side{ position:static; flex-direction:row; flex-wrap:wrap; }
  .media-side__lbl{ display:none; }
  .media-search{ margin-left:0; }
}
